  <metrics_definitions>
    <metric>
      <name>CTR (Click-Through Rate) %</name>
      <formula>(Clicks / Impressions) * 100</formula>
      <description>Shows the percentage of ad impressions that resulted in clicks</description>
      <business_use>Measures ad creative effectiveness and relevance to target audience</business_use>
    </metric>
    <metric>
      <name>CPC (Cost Per Click)</name>
      <formula>Total Spend / Clicks</formula>
      <description>Average cost to acquire one click from target audience</description>
      <business_use>Evaluates bidding strategy efficiency and platform costs</business_use>
    </metric>
    <metric>
      <name>CPA (Cost Per Acquisition)</name>
      <formula>Total Spend / Conversions</formula>
      <description>Average cost to achieve one conversion or customer acquisition</description>
      <business_use>Determines profitability threshold and budget allocation</business_use>
    </metric>
    <metric>
      <name>ROAS (Return on Ad Spend)</name>
      <formula>Revenue / Total Spend</formula>
      <description>Revenue generated for every $1 spent on ads (profit multiple)</description>
      <business_use>Primary profitability metric - guides budget reallocation decisions</business_use>
    </metric>
    <metric>
      <name>ROI % (Return on Investment)</name>
      <formula>((Revenue - Spend) / Spend) * 100</formula>
      <description>Percentage profit margin on advertising investment</description>
      <business_use>Shows net return as percentage - used for comparative performance analysis</business_use>
    </metric>
  </metrics_definitions>

